'========================
' Relationships
'========================

' Employer "1" --> "0..*" Job : posts

' JobSeeker "1" --> "0..*" JobApplication : submits

' Job "1" --> "0..*" JobApplication : receives

' JobApplication --> Job
' JobApplication --> JobSeeker

' User "1" --> "0..*" Notification

' Employer "1" --> "0..*" Review
' JobSeeker "1" --> "0..*" Review

' RecommendationEngine ..> Job
' RecommendationEngine ..> JobSeeker

' AuthService ..> User
' EmailService ..> User
' NotificationService ..> Notification

@enduml