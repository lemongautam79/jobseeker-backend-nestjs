'========================
' Recommendation Engine
'========================
class RecommendationEngine {
    +recommendJobs()
    +calculateSimilarity()
}

'========================
' Authentication
'========================
class AuthService {
    +register()
    +login()
    +verifyEmail()
    +refreshToken()
    +forgotPassword()
}

'========================
' Email Service
'========================
class EmailService {
    +sendOTP()
    +sendVerification()
    +sendApplicationStatus()
}

