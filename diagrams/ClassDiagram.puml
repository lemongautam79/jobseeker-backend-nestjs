@startuml
title Job Seeker - Class Diagram

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam dpi 180
left to right direction

'========================
' User
'========================
class User {
    +id: ObjectId
    +name: String
    +email: String
    +password: String
    +role: Role
    +avatar: String
    +isVerified: Boolean
    +status: UserStatus
}

class JobSeeker {
    +skills: List<String>
    ' +education: String
    +experience: String
    +resume: String
    ' +expectedSalary: Double
}

class Employer {
    +companyName: String
    +companyDescription: String
    ' +website: String
    +location: String
}

User <|-- JobSeeker
User <|-- Employer

'========================
' Job
'========================
class Job {
    +id: ObjectId
    +title: String
    +description: String
    +category: String
    +location: String
    +jobType: String
    +salary: Double
    +skills: List<String>
    ' +deadline: Date
    +status: JobStatus
}

'========================
' Job Application
'========================
class JobApplication {
    +id: ObjectId
    ' +coverLetter: String
    +status: ApplicationStatus
    +appliedAt: Date
}

